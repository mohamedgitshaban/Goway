            "body": { "mode": "raw", "raw": "{\n  \"name_en\": \"Economy\",\n  \"name_ar\": \"اقتصادي\",\n  \"price_per_km\": 0.50,\n  \"profit_margin\": 0.10\n}" },
            "url": { "raw": "{{base_url}}/admin/trip-types", "host": ["{{base_url}}"], "path": ["admin","trip-types"] }
          }
